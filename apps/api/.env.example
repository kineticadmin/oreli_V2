# ─── Base de données ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://oreli:oreli_dev@localhost:5432/oreli_dev"

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,exp://localhost:8081"

# ─── Auth JWT ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-in-production-min-32-chars"
JWT_REFRESH_SECRET="change-me-in-production-different-secret"
# Durée du token d'accès (ex: "15m", "1h")
JWT_ACCESS_EXPIRES_IN="15m"
# Durée du refresh token (ex: "30d")
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Admin ────────────────────────────────────────────────────────────────
ADMIN_API_KEY="change-me-in-production"

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Google AI Studio (Gemini) ────────────────────────────────────────────
GEMINI_API_KEY=AIza...   # Google AI Studio — aistudio.google.com (free tier)

# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT="oreli-dev"
GOOGLE_CLOUD_LOCATION="europe-west1"
# En développement local, utiliser Application Default Credentials (gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# ─── OAuth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
APPLE_CLIENT_ID="com.oreli.app"
APPLE_TEAM_ID="XXXXXXXXXX"

# ─── Email (Brevo) ────────────────────────────────────────────────────────
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="hello@oreli.ai"

# ─── Cloud Storage ────────────────────────────────────────────────────────
CLOUD_STORAGE_BUCKET_ASSETS="oreli-assets-dev"
CLOUD_STORAGE_BUCKET_PRIVATE="oreli-private-dev"
