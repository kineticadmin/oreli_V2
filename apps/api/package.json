    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
